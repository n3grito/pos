# Normalize line endings
* text=auto eol=lf

# PHP
*.php text diff=php

# Blade
*.blade.php text

# JavaScript / JSON
*.js text
*.json text

# CSS / PostCSS
*.css text
*.postcss text

# Config files
*.env text eol=lf
*.yml text
*.yaml text
*.xml text
*.config.js text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

# Shell scripts (must stay LF)
*.sh text eol=lf
