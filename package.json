{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "vite build",
        "dev": "vite",
        "cap:sync": "npx cap sync android",
        "cap:open": "npx cap open android",
        "cap:build": "npx cap copy android && cd android && .\\gradlew assembleDebug",
        "cap:url": "node -e \"const fs=require('fs');const c=JSON.parse(fs.readFileSync('capacitor.config.json'));c.server.url=process.argv[1];fs.writeFileSync('capacitor.config.json',JSON.stringify(c,null,2));console.log('URL updated to: '+process.argv[1])\""
    },
    "devDependencies": {
        "@capacitor/android": "^8.4.0",
        "@capacitor/cli": "^8.4.0",
        "@capacitor/core": "^8.4.0",
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "autoprefixer": "^10.4.2",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^3.1",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^8.0.0",
        "vite-plugin-full-reload": "^1.2.0"
    },
    "dependencies": {
        "alpinejs": "^3.4.2",
        "apexcharts": "^5.15.2"
    }
}
